    },
    {
      "definition": {
        "layout_type": "ordered",
        "title": "Accounting",
        "type": "group",
        "widgets": [
          {
            "definition": {
              "requests": [
                {
                  "display_type": "line",
                  "formulas": [
                    {
                      "alias": "Requests",
                      "formula": "default_zero(a) + default_zero(b)"
                    }
                  ],
                  "queries": [
                    {
                      "data_source": "metrics",
                      "name": "a",
                      "query": "sum:freeradius.total_acct_requests.count{$host}.as_rate()"
                    },
                    {
                      "data_source": "metrics",
                      "name": "b",
                      "query": "sum:freeradius.freeradius_total_acct_requests.count{$host}.as_rate()"
                    }
                  ],
                  "response_format": "timeseries",
                  "style": {
                    "palette": "blue"
                  }
                },
                {
                  "display_type": "line",
                  "formulas": [
                    {
                      "alias": "Responses",
                      "formula": "default_zero(c) + default_zero(d)"
                    }
                  ],
                  "queries": [
                    {
                      "data_source": "metrics",
                      "name": "c",
                      "query": "sum:freeradius.total_acct_responses.count{$host}.as_rate()"
                    },
                    {
                      "data_source": "metrics",
                      "name": "d",
                      "query": "sum:freeradius.freeradius_total_acct_responses.count{$host}.as_rate()"
                    }
                  ],
                  "response_format": "timeseries",
                  "style": {
                    "palette": "green"
                  }
                }
              ],
              "show_legend": true,
              "title": "Accounting Requests",
              "type": "timeseries"
            }
          },
          {
            "definition": {
              "requests": [
                {
                  "display_type": "bars",
                  "formulas": [
                    {
                      "alias": "Session Starts",
                      "formula": "starts"
                    }
                  ],
                  "queries": [
                    {
                      "compute": {
                        "aggregation": "count"
                      },
                      "data_source": "logs",
                      "indexes": [
                        "*"
                      ],
                      "name": "starts",
                      "search": {
                        "query": "service:radius-acct host:$host.value @site_name:$site.value @event:Acct-Start"
                      }
                    }
                  ],
                  "response_format": "timeseries",
                  "style": {
                    "palette": "green"
                  }
                },
                {
                  "display_type": "bars",
                  "formulas": [
                    {
                      "alias": "Session Stops",
                      "formula": "stops"
                    }
                  ],
                  "queries": [
                    {
                      "compute": {
                        "aggregation": "count"
                      },
                      "data_source": "logs",
                      "indexes": [
                        "*"
                      ],
                      "name": "stops",
                      "search": {
                        "query": "service:radius-acct host:$host.value @site_name:$site.value @event:Acct-Stop"
                      }
                    }
                  ],
                  "response_format": "timeseries",
                  "style": {
                    "palette": "red"
                  }
                }
              ],
              "show_legend": true,
              "title": "Session Events",
              "type": "timeseries"
            }
          },
          {
            "definition": {
              "requests": [
                {
                  "formulas": [
                    {
                      "formula": "query1 / 60"
                    }
                  ],
                  "queries": [
                    {
                      "compute": {
                        "aggregation": "avg",
                        "metric": "@session_time"
                      },
                      "data_source": "logs",
                      "group_by": [
                        {
                          "facet": "@device_owner",
                          "limit": 20,
                          "sort": {
                            "aggregation": "avg",
                            "metric": "@session_time",
                            "order": "desc"
                          }
                        }
                      ],
                      "indexes": [
                        "*"
                      ],
                      "name": "query1",
                      "search": {
                        "query": "service:radius-acct host:$host.value @site_name:$site.value @event:Acct-Stop"
                      }
                    }
                  ],
                  "response_format": "scalar"
                }
              ],
              "title": "Avg Session Duration by User (min)",
              "type": "toplist"
            }
          },
          {
            "definition": {
              "requests": [
                {
                  "formulas": [
                    {
                      "formula": "query1"
                    }
                  ],
                  "queries": [
                    {
                      "compute": {
                        "aggregation": "count"
                      },
                      "data_source": "logs",
                      "group_by": [
                        {
                          "facet": "@terminate_cause",
                          "limit": 10,
                          "sort": {
                            "aggregation": "count",
                            "order": "desc"
                          }
                        }
                      ],
                      "indexes": [
                        "*"
                      ],
                      "name": "query1",
                      "search": {
                        "query": "service:radius-acct host:$host.value @site_name:$site.value @event:Acct-Stop"
                      }
                    }
                  ],
                  "response_format": "scalar"
                }
              ],
              "title": "Session Termination Causes",
              "type": "toplist"
            }
          },
          {
            "definition": {
              "requests": [
                {
                  "display_type": "bars",
                  "formulas": [
                    {
                      "alias": "Input Bytes",
                      "formula": "input"
                    }
                  ],
                  "queries": [
                    {
                      "compute": {
                        "aggregation": "sum",
                        "metric": "@input_bytes"
                      },
                      "data_source": "logs",
                      "indexes": [
                        "*"
                      ],
                      "name": "input",
                      "search": {
                        "query": "service:radius-acct host:$host.value @site_name:$site.value @event:Acct-Stop"
                      }
                    }
                  ],
                  "response_format": "timeseries",
                  "style": {
                    "palette": "cool"
                  }
                },
                {
                  "display_type": "bars",
                  "formulas": [
                    {
                      "alias": "Output Bytes",
                      "formula": "output"
                    }
                  ],
                  "queries": [
                    {
                      "compute": {
                        "aggregation": "sum",
                        "metric": "@output_bytes"
                      },
                      "data_source": "logs",
                      "indexes": [
                        "*"
                      ],
                      "name": "output",
                      "search": {
                        "query": "service:radius-acct host:$host.value @site_name:$site.value @event:Acct-Stop"
                      }
                    }
                  ],
                  "response_format": "timeseries",
                  "style": {
                    "palette": "warm"
                  }
                }
              ],
              "show_legend": true,
              "title": "Bandwidth (Acct-Stop)",
              "type": "timeseries"
            }
          }
        ]
      }
    },
    {
      "definition": {
        "layout_type": "ordered",
        "title": "Infrastructure",
        "type": "group",
        "widgets": [
          {
            "definition": {
              "requests": [
                {
                  "display_type": "line",
                  "formulas": [
                    {
                      "alias": "Auth",
                      "formula": "default_zero(a) + default_zero(b)"
                    }
                  ],
                  "queries": [
                    {
                      "data_source": "metrics",
                      "name": "a",
                      "query": "avg:freeradius.queue_len_auth{$host}"
                    },
                    {
                      "data_source": "metrics",
                      "name": "b",
                      "query": "avg:freeradius.freeradius_queue_len_auth{$host}"
                    }
                  ],
                  "response_format": "timeseries"
                },
                {
                  "display_type": "line",
                  "formulas": [
                    {
                      "alias": "Acct",
                      "formula": "default_zero(c) + default_zero(d)"
                    }
                  ],
                  "queries": [
                    {
                      "data_source": "metrics",
                      "name": "c",
                      "query": "avg:freeradius.queue_len_acct{$host}"
                    },
                    {
                      "data_source": "metrics",
                      "name": "d",
