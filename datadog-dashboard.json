            }
          },
          {
            "definition": {
              "requests": [
                {
                  "formulas": [
                    {
                      "formula": "query1"
                    }
                  ],
                  "queries": [
                    {
                      "compute": {
                        "aggregation": "count"
                      },
                      "data_source": "logs",
                      "group_by": [
                        {
                          "facet": "@site_name",
                          "limit": 10,
                          "sort": {
                            "aggregation": "count",
                            "order": "desc"
                          }
                        },
                        {
                          "facet": "@ssid",
                          "limit": 10,
                          "sort": {
                            "aggregation": "count",
