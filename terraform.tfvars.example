# GCP project setup
billing_account_id = "XXXXXX-XXXXXX-XXXXXX"
org_id             = ""  # Leave empty if no org, or set to numeric org ID
folder_id          = ""  # Leave empty for org root

project_id   = "cloud-8021x"
project_name = "Cloud RADIUS 802.1X"

# Region / zones — primary and secondary VMs run in different zones for HA
region         = "us-east4"
zone           = "us-east4-a"
secondary_zone = "us-east4-c"

# VM sizing — FreeRADIUS + MariaDB need ~2 GB RAM
machine_type = "e2-medium"
disk_size_gb = 50

# Per-office RADIUS clients
# Each office gets a unique shared secret auto-generated by Terraform
# and stored in Secret Manager as "radius-shared-secret-<key>".
# Retrieve with: gcloud secrets versions access latest --secret=radius-shared-secret-nyc --project=<project-id>
radius_clients = {
  nyc = {
    cidrs       = ["203.0.113.1/32"]
    description = "NYC Ubiquiti UniFi APs"
  }
  atl = {
    cidrs       = ["203.0.113.2/32", "203.0.113.3/32"]
    description = "ATL Ubiquiti UniFi APs"
  }
  sacramento = {
    cidrs       = ["203.0.113.4/32"]
    description = "Sacramento Ubiquiti UniFi APs"
  }
}

# SSH access — default is GCP IAP tunnel only.
ssh_allowed_cidrs = [
  "35.235.240.0/20",    # GCP IAP range (for gcloud ssh --tunnel-through-iap)
  # "203.0.113.10/32",  # Optional: add your IP for direct SSH access
]

# RADIUS server certificate
# CN must match the Jamf WiFi profile "Trusted Server Certificate Names"
# Org is used in the CA and server cert subject (e.g. /O=Acme Corp/CN=...)
server_cert_cn  = "radius.example.com"
server_cert_org = "Example Corp"

# Datadog monitoring
# The agent collects infrastructure metrics, FreeRADIUS metrics (via Prometheus exporter),
# and ships logs to Datadog SIEM.
datadog_api_key = "CHANGE-ME-your-datadog-api-key"
# datadog_site  = "us5.datadoghq.com"  # default; uncomment to override

# Jamf Pro device owner lookup (optional)
# Enriches RADIUS auth logs with the assigned user's email.
# Also overwrites the EAP identity so UniFi/accounting shows email instead of serial number.
# Requires a Jamf Pro API Client with "Read Computers" privilege.
# jamf_url           = "https://yourorg.jamfcloud.com"
# jamf_client_id     = "your-api-client-id"
# jamf_client_secret = "your-api-client-secret"

# Okta Intermediate CA certificate (PEM format)
# This is the trust anchor for SCEP client certs issued via Jamf/Okta.
# Paste the full PEM content, or use: okta_ca_cert_pem = file("freeradius/freeradius-wifi-auth/certs/okta-ca.pem")
okta_ca_cert_pem = <<-EOT
-----BEGIN CERTIFICATE-----
PASTE YOUR OKTA INTERMEDIATE CA CERTIFICATE HERE
-----END CERTIFICATE-----
EOT

# Okta Root CA certificate (optional, PEM format)
# Enables full chain validation: client cert → Intermediate → Root.
# Without this, FreeRADIUS trusts only the Intermediate CA directly (still works).
# See README for instructions on obtaining this from your Okta admin console.
# okta_root_ca_cert_pem = <<-EOT
# -----BEGIN CERTIFICATE-----
# PASTE YOUR OKTA ROOT CA CERTIFICATE HERE
# -----END CERTIFICATE-----
# EOT
